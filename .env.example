DATABASE_URL=[REDACTED_HH_POSTGRES_URL]
# Optional legacy/backup compatibility only:
NEON_DATABASE_URL=[REDACTED_LEGACY_NEON_URL]
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
WHOP_API_KEY=your-whop-api-key
WHOP_CLIENT_ID=your-whop-oauth-client-id
WHOP_CLIENT_SECRET=your-whop-oauth-client-secret
WHOP_PRO_PLAN_ID=plan_xxxxx
WHOP_ALPHA_PLAN_ID=plan_xxxxx
# Legacy fallback accepted for one release:
WHOP_ELITE_PLAN_ID=plan_xxxxx
WHOP_WEBHOOK_KEY=your-whop-webhook-key
WHOP_CHECKOUT_URL_PRO_MONTHLY=https://whop.com/checkout/...
WHOP_CHECKOUT_URL_PRO_ANNUAL=https://whop.com/checkout/...
WHOP_CHECKOUT_URL_ALPHA_MONTHLY=https://whop.com/checkout/...
WHOP_CHECKOUT_URL_ALPHA_ANNUAL=https://whop.com/checkout/...
SESSION_SECRET=generate-a-random-32-char-string-here
# Dedicated non-rotating key for encrypting stored webhook signing secrets; do not reuse SESSION_SECRET.
WEBHOOK_SECRET_ENCRYPTION_KEY=generate-a-random-32-char-string-here
NEXT_PUBLIC_BASE_URL=https://call-score.com
REVIEW_ACCESS_TOKEN=generate-a-random-32-char-review-token-here
CRON_SECRET=generate-a-random-secret-here
PIPELINE_STATUS_SECRET=generate-a-random-pipeline-status-secret-here
OLLAMA_API_KEY=your-ollama-cloud-api-key
ML_VERIFIER_PROVIDER=ollama
ML_VERIFIER_MODEL=deepseek-v4-flash
ALERTS_BASE_URL=https://call-score.com
ALERTS_CLAIM_BATCH=500
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alerts@example.com
# Optional Sentry monitoring (safe to leave unset in local/test environments)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
