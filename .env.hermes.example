# Copy to .env.hermes on Hermes/Hetzner. Do not commit real secrets.
NEON_DATABASE_URL=postgres://user:password@host/db?sslmode=require
OLLAMA_API_KEY=ollama_cloud_api_key

# Optional overrides
HERMES_WORKER_ID=hermes-1
ML_VERIFIER_PROVIDER=ollama
ML_VERIFIER_MODEL=deepseek-v4-flash
ML_VERIFIER_PROMPT_VERSION=ml-verifier-v1
ML_VERIFIER_TIMEOUT_MS=180000
OLLAMA_HOST=https://ollama.com
